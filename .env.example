# ===== Public (exposed to the browser) =====

# Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://raqeem.ma

# URL of the Raqeem application (login target)
NEXT_PUBLIC_APP_URL=https://app.raqeem.ma

# Social links — leave empty to hide the corresponding link
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Analytics — leave empty to disable analytics entirely
NEXT_PUBLIC_ANALYTICS_ID=

# ===== Server-only (never exposed to the browser) =====

# Where demo requests / contact messages are delivered
CONTACT_TO_EMAIL=
DEMO_TO_EMAIL=
EMAIL_FROM=
EMAIL_PROVIDER_API_KEY=

# Cloudflare Turnstile (optional spam protection)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
